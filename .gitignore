# =====================================================
# Healthcare App — root .gitignore (monorepo)
# =====================================================

# ---- Environment / secrets (NEVER commit) ----
.env
.env.*
!.env.example

# ---- Python / backend ----
venv/
.venv/
env/
__pycache__
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# ---- Node / frontend ----
node_modules/
dist/
build/
.next/
*.local
package-lock.json
public/logo.png

# ---- Editors / IDEs ----
.vscode/
.idea/
*.swp

# ---- OS ----
.DS_Store
Thumbs.db

# ---- Logs ----
*.log

# local databases / smoke-test artifacts
*.db
!Thumbs.db
